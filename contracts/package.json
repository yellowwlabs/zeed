{
  "name": "contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/luna.compact ./dist",
    "ci": "pnpm run compact && pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run test",
    "compact": "compact compile src/accreditation.compact ./src/managed/accreditation.compact",
    "lint": "eslint src",
    "prepack": "pnpm build",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.4",
    "@midnight-ntwrk/midnight-js-types": "^4.0.4",
    "@midnight-ntwrk/compact-runtime": "^0.16.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  }
}
