{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./frontend/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "frontend/**/*.ts",
    "frontend/**/*.tsx",
    ".next/types/**/*.ts",
    "backend/src/root.ts",
    "backend/src/trpc.ts",
    "backend/src/lib/db.ts",
    "backend/src/lib/auth.ts"
  ],
  "exclude": ["node_modules", "backend", "contracts"]
}
