// Fundraise SaaS — Prisma Schema
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// IDENTITY & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String
  passwordHash  String?
  image         String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  companyMembers     CompanyMember[]
  investorMembers    InvestorMember[]
  signatures         Signature[]
  auditEvents        AuditEvent[]
  accreditationProof AccreditationProof?
  walletConnection   WalletConnection?
  banners            Banner[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// COMPANIES (ISSUERS)
// ============================================================

model Company {
  id               String   @id @default(cuid())
  legalName        String
  dba              String?
  stateOfIncorp    String   @default("DE")
  entityType       String   @default("C-Corp")
  ein              String?
  formationDate    DateTime?
  fiscalYearEnd    String?  @default("12-31")
  primaryAddress   Json
  authorizedShares BigInt?
  parValue         Decimal? @db.Decimal(20, 10)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members         CompanyMember[]
  capTableEntries CapTableEntry[]
  deals           Deal[]
  documents            Document[]
  founderMajorityProof FounderMajorityProof?
}

model CompanyMember {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

// ============================================================
// INVESTORS
// ============================================================

model Investor {
  id               String   @id @default(cuid())
  entityName       String
  entityType       String
  jurisdiction     String   @default("DE")
  address          Json
  wireInstructions Json?
  taxId            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members     InvestorMember[]
  investments Investment[]
}

model InvestorMember {
  id         String   @id @default(cuid())
  userId     String
  investorId String
  role       String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  investor Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([userId, investorId])
}

model AccreditationProof {
  id              String    @id @default(cuid())
  userId          String    @unique
  midnightProofId String?
  contractAddress String?
  proofType       String
  verifiedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// CAP TABLE
// ============================================================

model CapTableEntry {
  id                String   @id @default(cuid())
  companyId         String
  holderName        String
  holderEmail       String?
  securityType      String
  shareCount        BigInt?
  pricePerShare     Decimal? @db.Decimal(20, 10)
  issueDate         DateTime
  vestingScheduleId String?
  certificateNum    String?
  notes             String?
  createdAt         DateTime @default(now())

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vestingSchedule VestingSchedule? @relation(fields: [vestingScheduleId], references: [id])

  @@index([companyId])
}

model VestingSchedule {
  id             String   @id @default(cuid())
  totalShares    BigInt
  startDate      DateTime
  cliffMonths    Int      @default(12)
  durationMonths Int      @default(48)
  acceleration   String?

  entries CapTableEntry[]
}

// ============================================================
// DEALS & INSTRUMENTS
// ============================================================

model Deal {
  id              String    @id @default(cuid())
  companyId       String
  name            String
  dealType        String
  status          String    @default("DRAFT")
  targetAmount    Decimal   @db.Decimal(20, 2)
  minimumAmount   Decimal?  @db.Decimal(20, 2)
  closingDeadline DateTime?
  defaultTerms    Json
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investments   Investment[]
  documents     Document[]
  dataRoomItems DataRoomItem[]

  @@index([companyId])
  @@index([status])
}

model Investment {
  id             String    @id @default(cuid())
  dealId         String
  investorId     String
  instrumentType String
  amount         Decimal   @db.Decimal(20, 2)
  status         String    @default("INVITED")
  terms          Json
  invitedAt      DateTime  @default(now())
  agreedAt       DateTime?
  signedAt       DateTime?
  fundedAt       DateTime?
  closedAt       DateTime?

  deal             Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  investor         Investor          @relation(fields: [investorId], references: [id], onDelete: Cascade)
  documents        Document[]
  conversionEvents ConversionEvent[]

  @@index([dealId])
  @@index([investorId])
}

model ConversionEvent {
  id              String   @id @default(cuid())
  investmentId    String
  eventType       String
  triggerDate     DateTime
  conversionPrice Decimal? @db.Decimal(20, 10)
  sharesIssued    BigInt?
  payoutAmount    Decimal? @db.Decimal(20, 2)
  notes           String?
  createdAt       DateTime @default(now())

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
}

// ============================================================
// DOCUMENTS & SIGNATURES
// ============================================================

model DocumentTemplate {
  id             String   @id @default(cuid())
  name           String
  version        String
  documentType   String
  templateBody   String   @db.Text
  variableSchema Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([documentType, version])
}

model Document {
  id              String    @id @default(cuid())
  templateId      String?
  companyId       String?
  dealId          String?
  investmentId    String?
  documentType    String
  title           String
  status          String    @default("DRAFT")
  renderedContent String    @db.Text
  pdfStorageKey   String?
  contentHash     String
  variables       Json
  createdAt       DateTime  @default(now())
  finalizedAt     DateTime?
  fullySignedAt   DateTime?

  company         Company?         @relation(fields: [companyId], references: [id])
  deal            Deal?            @relation(fields: [dealId], references: [id])
  investment      Investment?      @relation(fields: [investmentId], references: [id])
  signatureBlocks SignatureBlock[]
  signatures      Signature[]

  @@index([dealId])
  @@index([investmentId])
  @@index([status])
}

model SignatureBlock {
  id           String    @id @default(cuid())
  documentId   String
  signerName   String
  signerEmail  String
  signerRole   String
  pageNumber   Int
  positionX    Int
  positionY    Int
  signingOrder Int       @default(0)
  signedAt     DateTime?

  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatures Signature[]

  @@index([documentId])
}

model Signature {
  id                   String   @id @default(cuid())
  documentId           String
  signatureBlockId     String
  userId               String
  signedAt             DateTime @default(now())
  ipAddress            String
  userAgent            String
  signatureMethod      String
  signatureImageKey    String?
  contentHashAtSigning String

  document       Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signatureBlock SignatureBlock @relation(fields: [signatureBlockId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id])
}

// ============================================================
// DATA ROOM
// ============================================================

model DataRoomItem {
  id         String   @id @default(cuid())
  dealId     String
  folderPath String
  fileName   String
  storageKey String
  mimeType   String
  size       Int
  uploadedBy String
  uploadedAt DateTime @default(now())

  deal         Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  accessGrants DataRoomAccess[]
}

model DataRoomAccess {
  id         String    @id @default(cuid())
  itemId     String
  investorId String
  permission String
  watermark  Boolean   @default(true)
  expiresAt  DateTime?
  grantedAt  DateTime  @default(now())

  item DataRoomItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

// ============================================================
// AUDIT
// ============================================================

model AuditEvent {
  id           String   @id @default(cuid())
  userId       String?
  eventType    String
  resourceType String
  resourceId   String
  metadata     Json
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([userId])
}

// ============================================================
// MIDNIGHT WALLET & ZK PROOFS
// ============================================================

model WalletConnection {
  id                  String   @id @default(cuid())
  userId              String   @unique
  networkId           String
  encryptionPublicKey String   @unique
  coinPublicKey       String
  connectedAt         DateTime @default(now())
  lastSeenAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FounderMajorityProof {
  id              String    @id @default(cuid())
  companyId       String    @unique
  contractAddress String?
  thresholdBps    Int
  lastProofValid  Boolean   @default(false)
  proofCount      Int       @default(0)
  provedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ============================================================
// BANNERS
// ============================================================

model Banner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String?
  ctaText     String?
  ctaUrl      String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([isActive, order])
}
